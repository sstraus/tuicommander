{
  "name": "tuicommander",
  "private": true,
  "version": "1.2.4-nightly",
  "description": "Multi-agent terminal orchestrator with native terminal and Tauri",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
